// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}
// --- ENUMS ---
enum Role {
  SUPERADMIN     // Operates the whole SaaS
  ADMIN          // SaaS staff
  LOCAL_ADMIN    // Society committee member/manager
  USER           // Standard resident
}

enum FinancialHead {
  CURRENT_ASSET
  CURRENT_LIABILITY
  FIXED_ASSET
  INCOME
  EXPENSE
  CAPITAL
  LOANS
  SUNDRY_CREDITORS
  SUNDRY_DEBTORS
}

enum AccountCalculationType {
  FIXED
  PERCENTAGE
  SQFT
}

enum BillFrequency {
  MONTHLY
  BIMONTHLY
  TRIMONTHLY
  QUARTERLY
  SEMESTER
  YEARLY
}

// --- TABLES ---

// 1. The Single Source of Truth for Logins
model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // A user can manage multiple societies (if they are a LOCAL_ADMIN)
  managedSocieties SocietyAccess[] 
  
  // A user can own/rent flats in multiple societies
  members   MemberProfile[] 
}

// 2. The Tenant (The Housing Society)
model Society {
  id                        String        @id @default(cuid())
  name                      String
  address                   String?
  registrationNumber        String?
  chairman                  String?
  secretary                 String?
  treasurer                 String?
  auditor                   String?
  fixedInterestEnabled      Boolean       @default(false)
  fixedInterestValue        Decimal       @default(0) @db.Decimal(12, 3)
  interestRebateValue       Decimal       @default(0) @db.Decimal(12, 3)
  interestRebateGraceDays   Int           @default(0)
  simpleInterestRateMonthly Decimal       @default(0.175) @db.Decimal(12, 3)
  billGenerationDay         Int           @default(1)
  billFrequency             BillFrequency @default(MONTHLY)
  createdAt                 DateTime      @default(now())
  
  managers       SocietyAccess[]
  flats          Flat[]
  members        MemberProfile[]
  ledgerConfigs SocietyLedgerConfig[]
  standardRates FlatStandardRate[]
  bills         Bill[]
  transactions   Transaction[]
  receipts       Receipt[]
}

model Flat {
  id         String          @id @default(cuid())
  societyId   String
  flatNo      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  society     Society        @relation(fields: [societyId], references: [id], onDelete: Cascade)
  owners      MemberProfile[]

  @@unique([societyId, flatNo])
}

// 3. The Access Link (Who manages which society?)
model SocietyAccess {
  id        String   @id @default(cuid())
  userId    String
  societyId String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([userId, societyId]) 
}

// 4. The Resident Profile (Ledger data, flat numbers, etc.)
model MemberProfile {
  id              String   @id @default(cuid())
  flatId          String?
  flatNo          String
  salutation      String?  // e.g., Mr., Mrs., Dr.
  firstName       String
  lastName        String?
  contactNumber   String?
  email           String?
  areaSqFt        Float?
  memberSince     DateTime @default(now())
  ownershipStartDate DateTime @default(now())
  ownershipEndDate DateTime?
  isActive        Boolean  @default(true)
  
  // Financials
  openingBalance  Decimal  @default(0) @db.Decimal(12, 2)
  openingInterest Decimal  @default(0) @db.Decimal(12, 2)
  // To view all bills issued to this specific member
  bills           Bill[]

  // To view all receipts issued for payments made by this member
  receipts        Receipt[]

  // To view the complete financial ledger (Charges and Payments) for this member
  transactions    Transaction[]
  // Relationship to Society
  societyId       String
  society         Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  flat            Flat?    @relation(fields: [flatId], references: [id], onDelete: Cascade)

  
// FIX: Add this field to link back to the User model
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

//master ledger--universal for all societies
model GlobalLedgerHead {
  id                     String                 @id @default(cuid())
  name                   String                 @unique // e.g., "Water Charges", "Elevator Maintenance"
  financialHead          FinancialHead          @default(INCOME)
  defaultCalculationType AccountCalculationType @default(FIXED)
  description            String?
  
  // Relation to the society-specific configurations
  societyConfigs SocietyLedgerConfig[]
}

// Society-specific toggle
model SocietyLedgerConfig {
  id                 String                 @id @default(cuid())
  societyId          String
  globalLedgerHeadId String?
  accountName        String
  financialHead      FinancialHead
  calculationType    AccountCalculationType @default(FIXED)
  isActive           Boolean                @default(false)
  includeInMaintenanceBill Boolean          @default(false)
  interestApplicable Boolean                @default(false)
  defaultAmount      Decimal                @default(0) @db.Decimal(12, 2)
  society            Society                @relation(fields: [societyId], references: [id], onDelete: Cascade)
  globalLedgerHead   GlobalLedgerHead?      @relation(fields: [globalLedgerHeadId], references: [id], onDelete: Cascade)
  standardRates      FlatStandardRate[]

  @@unique([societyId, globalLedgerHeadId])
  @@unique([societyId, accountName])
}

model FlatStandardRate {
  id                   String             @id @default(cuid())
  societyId            String
  flatNo               String
  societyLedgerConfigId String
  amount               Decimal            @default(0) @db.Decimal(12, 2)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  society              Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  ledgerConfig         SocietyLedgerConfig @relation(fields: [societyLedgerConfigId], references: [id], onDelete: Cascade)

  @@unique([societyId, flatNo, societyLedgerConfigId])
  @@index([societyId, flatNo])
  @@index([societyLedgerConfigId])
}

// --- 1. BILLING SYSTEM ---

model Bill {
  id             String      @id @default(cuid())
  billNumber     String      // e.g., SOC/2026/FEB/101
  billDate       DateTime    @default(now())
  dueDate        DateTime
  billingYear    Int
  billingMonth   Int
  
  societyId      String
  society        Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  memberId       String
  member         MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  previousAmount Decimal     @default(0) @db.Decimal(12, 2)
  previousInterest Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal     @db.Decimal(12, 2)
  currentInterest Decimal    @default(0) @db.Decimal(12, 2)
  totalOutstanding Decimal   @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal     @default(0) @db.Decimal(12, 2)
  status         BillStatus  @default(UNPAID)

  items          BillItem[]
  transaction    Transaction? // Optional: Link to the CHARGE transaction

  @@unique([societyId, billNumber])
  @@unique([societyId, memberId, billingYear, billingMonth])
  @@index([societyId, billDate])
  @@index([societyId, billingYear, billingMonth])
  @@index([memberId])
}

model BillItem {
  id             String   @id @default(cuid())
  billId         String
  bill           Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  
  ledgerHeadName String   // e.g., "MAINTENANCE CHARGES"
  amount         Decimal  @db.Decimal(12, 2)
}

// --- 2. COLLECTION SYSTEM ---

model Receipt {
  id             String      @id @default(cuid())
  receiptNumber  String      @unique // e.g., REC-2026-0001
  amount         Decimal     @db.Decimal(12, 2)
  paymentMode    String      // CASH, CHEQUE, UPI, NEFT
  
  referenceNo    String?     // Cheque No or UPI Ref
  bankName       String?
  remarks        String?
  receiptDate    DateTime    @default(now())
  
  societyId      String
  society        Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  memberId       String
  member          MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactionId  String      @unique // Link to the PAYMENT transaction

  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([societyId, receiptDate])
  @@index([memberId])
}

// --- 3. THE UNIFIED LEDGER ---

model Transaction {
  id          String    @id @default(cuid())
  date        DateTime  @default(now())
  financialYear String  // e.g., "2025-26" - Useful for I&E Reports
  
  type        TransType // CHARGE (Income Accrual), PAYMENT (Cash In), EXPENSE (Cash Out)
  category    String    // e.g., "Monthly Dues", "Plumbing Repair", "Bank Interest"
  
  amount      Decimal   @db.Decimal(12, 2)
  description String?   
  
  societyId   String
  society     Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  
  memberId    String?   // Nullable for general society expenses
  member      MemberProfile? @relation(fields: [memberId], references: [id], onDelete: Cascade)
  billId      String?   @unique // Link back to Bill if type is CHARGE
  
  bill        Bill?     @relation(fields: [billId], references: [id])
  receipt     Receipt?

  // SPEED INDEXES
  @@index([societyId, date])
  @@index([memberId, date])
  @@index([type, financialYear])
}

enum BillStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TransType {
  CHARGE      // Bill generated (Income)
  PAYMENT     // Receipt recorded (Cash In)
  EXPENSE     // Society spending (Cash Out)
  OTHER_INCOME // e.g., Interest or Clubhouse rent
}
